<?xml version="1.0" encoding="utf-8"?>
<!--
  Dark-fill variant of ic_fuel_bottle, used by the carb/hyd log fields ONLY when:
    1. The slot's idle background is FIELD_COLOR_AUTO (Karoo-theme passthrough), AND
    2. The Karoo is currently in day mode.
  In that combo the host paints a white field background, so the white-filled
  default drawable disappears. This black-filled version restores visibility.
  Geometry is identical to ic_fuel_bottle.xml — only the fill colours flip
  (white → near-black, dark accent → light accent for matching contrast).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <path
        android:fillColor="#FF000000"
        android:pathData="M10.5,1.5 L13.5,1.5 L13.5,3 L10.5,3 Z" />

    <path
        android:fillColor="#FF000000"
        android:pathData="M9.5,3 L14.5,3 L14.5,5 L9.5,5 Z" />

    <path
        android:fillColor="#FF000000"
        android:pathData="M9.5,5 L14.5,5 A2,2 0 0 1 16.5,7 L16.5,20.5 A1.5,1.5 0 0 1 15,22 L9,22 A1.5,1.5 0 0 1 7.5,20.5 L7.5,7 A2,2 0 0 1 9.5,5 Z" />

    <path
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.35"
