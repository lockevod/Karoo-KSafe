<?xml version="1.0" encoding="utf-8"?>
<!-- Root FrameLayout adds horizontal margin so the card doesn't touch screen edges -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="5dp"
    android:paddingEnd="5dp"
    android:paddingTop="6dp"
    android:paddingBottom="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_sos_overlay"
        android:clipToOutline="true"
        android:elevation="12dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingEnd="10dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp">

        <!-- Warning icon -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="10dp"
            android:text="⚠"
            android:textColor="#FFFF99"
            android:textSize="28sp" />

        <!-- Info column: title, reason, countdown -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="KSafe SOS"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:maxLines="1"
                android:ellipsize="none" />

            <TextView
                android:id="@+id/tv_sos_reason"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFCCCC"
                android:textSize="12sp"
                android:layout_marginTop="1dp" />

            <TextView
                android:id="@+id/tv_sos_countdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="34sp"
                android:textStyle="bold"
                android:layout_marginTop="2dp"
                android:includeFontPadding="false" />

        </LinearLayout>

        <!-- Cancel button with rounded corners -->
        <TextView
            android:id="@+id/btn_cancel_sos"
            android:layout_width="100dp"
            android:layout_height="62dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_cancel_button"
            android:clipToOutline="true"
            android:gravity="center"
            android:text="CANCEL"
            android:textColor="#CC0000"
            android:textSize="14sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

</FrameLayout>
