<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <application
        android:name=".KSafeApplication"
        android:allowBackup="true"
        android:icon="@drawable/ic_ksafe"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_ksafe"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppCompat">

        <activity
            android:name=".activity.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Transparent activity used as fallback cancel mechanism (BonusAction, future deep links). -->
        <activity
            android:name=".activity.CancelEmergencyActivity"
            android:exported="true"
            android:noHistory="true"
            android:theme="@android:style/Theme.NoDisplay" />

        <!-- BroadcastReceiver for data field taps. Each field uses a unique intent action
             so Android creates genuinely different PendingIntents without launching any
             Activity (no screen change during a ride). -->
        <receiver
            android:name=".activity.FieldTapReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.enderthor.kSafe.TAP_SOS" />
                <action android:name="com.enderthor.kSafe.TAP_TIMER" />
                <action android:name="com.enderthor.kSafe.TAP_CUSTOM_MESSAGE" />
                <action android:name="com.enderthor.kSafe.TAP_CUSTOM_MESSAGE_2" />
                <action android:name="com.enderthor.kSafe.TAP_CUSTOM_MESSAGE_3" />
                <action android:name="com.enderthor.kSafe.TAP_WEBHOOK_1" />
                <action android:name="com.enderthor.kSafe.TAP_WEBHOOK_2" />
            </intent-filter>
        </receiver>

        <service
            android:name=".extension.KSafeExtension"
            android:exported="true"
            tools:ignore="ExportedService">
            <intent-filter>
                <action android:name="io.hammerhead.karooext.KAROO_EXTENSION" />
            </intent-filter>
            <meta-data
                android:name="io.hammerhead.karooext.EXTENSION_INFO"
                android:resource="@xml/extension_info" />
        </service>

        <meta-data
            android:name="io.hammerhead.karooext.MANIFEST_URL"
            android:value="https://github.com/lockevod/Karoo-KSafe/releases/latest/download/manifest.json" />
    </application>

</manifest>
